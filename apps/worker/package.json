{
  "name": "worker",
  "version": "0.15.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "test": "vitest run",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "node -e \"console.error('Use explicit deploy:saiyo-pro or deploy:tenshoku-pro'); process.exit(1)\"",
    "deploy:saiyo-pro": "vite build && wrangler deploy --config wrangler.saiyo-pro.toml",
    "deploy:tenshoku-pro": "vite build && wrangler deploy --config wrangler.toml",
    "d1:saiyo-pro": "wrangler d1 execute saiyo-pro-harness --remote --config wrangler.saiyo-pro.toml",
    "d1:tenshoku-pro": "wrangler d1 execute baudroie-harness --remote --config wrangler.toml",
    "setup:five-rpo": "tsx scripts/setup-five-rpo.ts",
    "setup:saiyo-pro-intake": "tsx scripts/setup-saiyo-pro-candidate-intake.ts",
    "attach:saiyou-pro": "tsx scripts/attach-saiyou-pro-product.ts",
    "typecheck": "tsc --noEmit",
    "inject-version": "tsx scripts/inject-version.ts"
  },
  "dependencies": {
    "@line-crm/db": "workspace:*",
    "@line-crm/line-sdk": "workspace:*",
    "@line-crm/shared": "workspace:*",
    "@line-harness/update-engine": "workspace:*",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20241205.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0",
    "wrangler": "^4.0.0"
  }
}
